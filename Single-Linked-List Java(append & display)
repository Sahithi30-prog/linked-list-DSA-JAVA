/*
Java Program to create a single linked list	and 
display the elements of the linked list
Sample Input and Output:
input=
5
1 2 3 4 5
output=1 2 3 4 5
*/
import java.util.*;
class node
{
    int data;
    node next;
}
class LinkedList
{
    node head;
    LList()
    {
        head=null;
    }
	//Inserting values into Linked list
    void append(int x)
    {
        node nn=new node();
        nn.data=x;
        nn.next=null;
        if(head==null)
        {
            head=nn;
            return;
        }
        node temp=head;
        while(temp.next!=null)
        {
            temp=temp.next;
        }
        temp.next=nn;
    }
	//logic to display
    void display()
    {
        if(head==null)
        {
            System.out.println("List is empty");
            return;
        }
        node temp=head;
        while(temp!=null)
        {
            System.out.print(temp.data+" ");
            temp=temp.next;
        }
    }
}
//Main class 
class Main
{
    public static void main(String args[])
    {
        Scanner sc=new Scanner(System.in);
        LList l=new LList();
        int n=sc.nextInt();
        for(int i=0;i<n;i++)
        {
            int x=sc.nextInt();
            l.append(x);
    
        }
        l.display();
    }
}
