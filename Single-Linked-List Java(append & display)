/*
Java Program to create a single linked list	and 
display the elements of the linked list
Sample Input and Output:
input=
5
1 2 3 4 5
output=1 2 3 4 5
*/
import java.util.*;
class node
{
    int data;
    node next;
}
class LinkedList
{
    node head;
    LinkedList()
    {
        head=null;
    }
	//Inserting values into Linked list
    void append(int x)
    {
        node nn=new node();
        nn.data=x;
        nn.next=null;
        if(head==null)
        {
            head=nn;
            return;
        }
        node temp=head;
        while(temp.next!=null)
        {
            temp=temp.next;
        }
        temp.next=nn;
    }
	//logic to display
    void display()
    {
        if(head==null)
        {
            System.out.println("List is empty");
            return;
        }
        node temp=head;
        while(temp!=null)
        {
            System.out.print(temp.data+" ");
            temp=temp.next;
        }
		System.out.println();
    }
//logic to reverse
void reverse()
    {
		node prev = null;
		node curr = head;
		while(curr != null) {
		    node next = curr.next;
		    curr.next = prev;
		    prev = curr;
		    curr = next;
    }
head = prev;
}
//logic to palindrome
void palindrome()
    {
        Stack<Integer> s= new Stack<>();
        node temp=head;
		boolean isPalindrome = true;
        while(temp!=null)
        {
          s.push(temp.data);
          temp=temp.next;
        }  
        temp=head;
        while(temp!=null)
        {
          if(temp.data!=s.pop())
          {
				isPalindrome = false;
   				break;
          }
          temp=temp.next;
        }
         if(isPalindrome)
            System.out.println("Palindrome: true");
        else
            System.out.println("Palindrome: false");   
    }
}
//Main class 
class Main
{
    public static void main(String args[])
    {
        Scanner sc=new Scanner(System.in);
        LinkedList l=new LinkedList();
        int n=sc.nextInt();
        for(int i=0;i<n;i++)
        {
            int x=sc.nextInt();
            l.append(x);
    
        }
		//To display whole Linked List
        l.display();
		//TO get the reverse 
		l.reverse();
		System.out.print("Reversed: ");
		l.display();
		//To whether Palindrome or not
		l.palindrome();
    }
}
