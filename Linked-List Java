import java.util.*;
class node
{
    int data;
    node next;
}
class LinkedList
{
    node head;
    LinkedList()
    {
        head=null;
    }
	//Inserting values into Linked list
    void append(int x)
    {
        node nn=new node();
        nn.data=x;
        nn.next=null;
        if(head==null)
        {
            head=nn;
            return;
        }
        node temp=head;
        while(temp.next!=null)
        {
            temp=temp.next;
        }
        temp.next=nn;
    }
	//logic to display
    void display()
    {
        if(head==null)
        {
            System.out.println("List is empty");
            return;
        }
        node temp=head;
        while(temp!=null)
        {
            System.out.print(temp.data+" ");
            temp=temp.next;
        }
		System.out.println();
    }
	//logic to reverse
	void reverse()
	    {
			node prev = null;
			node curr = head;
			while(curr != null) {
			    node next = curr.next;
			    curr.next = prev;
			    prev = curr;
			    curr = next;
	    }
	head = prev;
}
	//logic to palindrome
	void palindrome()
	    {
	        Stack<Integer> s= new Stack<>();
	        node temp=head;
			boolean isPalindrome = true;
	        while(temp!=null)
	        {
	          s.push(temp.data);
	          temp=temp.next;
	        }  
	        temp=head;
	        while(temp!=null)
	        {
	          if(temp.data!=s.pop())
	          {
					isPalindrome = false;
	   				break;
	          }
	          temp=temp.next;
	        }
	         if(isPalindrome)
	            System.out.println("Palindrome: true");
	        else
	            System.out.println("Palindrome: false");   
	    }
	//to delete a position
	void deleteAtPosition(int pos) {
	    if (head == null) {
	        System.out.println("List is empty");
	        return;
	    }
		if (pos <= 0) {
		    System.out.println("Invalid position");
		    return;
		}
	    node temp = head;
	    // If first node
	    if (pos == 1) {
	        head = temp.next;
	        return;
	    }
	    for (int i = 1; temp != null && i < pos - 1; i++) {
	        temp = temp.next;
	    }
	    if (temp == null || temp.next == null) {
	        System.out.println("Invalid position");
	        return;
	    }
	
	    temp.next = temp.next.next;
	}
}
//Main class 
class Main
{
    public static void main(String args[])
    {
        Scanner sc=new Scanner(System.in);
        LinkedList l=new LinkedList();
        int n=sc.nextInt();
        for(int i=0;i<n;i++)
        {
            int x=sc.nextInt();
            l.append(x);
    
        }
		//To display whole Linked List
        l.display();
		//TO get the reverse 
		l.reverse();
		System.out.print("Reversed: ");
		l.display();
		//To know whether Palindrome or not
		l.palindrome();
		//to delete a value with its position
		System.out.println("Give position to delete");
		int pos=sc.nextInt();
		l.deleteAtPosition(pos);
		System.out.println("After Deletion:/n");
		l.display()
    }
}
